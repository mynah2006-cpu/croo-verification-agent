AGENT_ID=croo-verifier-unique-id
SETTLEMENT_ADDRESS=0xDeAdBeEf00000000000000000000000000000001
CAP_SECRET=croo-hackathon-secret-2026
FEE_UNITS_PER_CALL=100
HOST=0.0.0.0
PORT=8000
DEV=true

# ── LLM Backend (SemanticAnalysisAgent) ────────────────────────────────────
# Set ONE of the following keys to enable real LLM-powered analysis.
# Priority: XAI_API_KEY > SKYWORK_API_KEY > graceful stub fallback.
XAI_API_KEY=                     # xAI Grok API key  → https://api.x.ai/v1
SKYWORK_API_KEY=                 # Skywork API key   → https://api.skywork.ai/v1

# Optional LLM tuning (defaults shown)
LLM_TIMEOUT_SECONDS=25           # Max seconds to wait for an LLM response
LLM_MAX_TOKENS=700               # Max tokens in the LLM completion

# ── Network Topology Simulation Constants ───────────────────────────────────
# Derived from a 30,000-transaction Monte-Carlo simulation of the CROO graph.
# These are served via GET /cap/manifest → network_topology_reputation.
# Override here to re-tune without changing source code (12-factor compliant).
NETWORK_PAGERANK=0.0142          # PageRank authority score  (Top 5% threshold)
NETWORK_CENTRALITY=Top 5% Autonomous Authority   # Eigenvector-centrality label
NETWORK_TX_SUCCESS=0.9796        # Transaction success rate  (97.96%)
NETWORK_LATENCY_MS=711.83        # Aggregated p50 latency in ms
NETWORK_SIM_TX_COUNT=30000       # Simulation corpus size
NETWORK_SIM_METHOD=Monte-Carlo / PageRank over 500-node CROO agent graph; 30,000 transactions

